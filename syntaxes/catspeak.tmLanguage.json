{
  "name": "Catspeak",
  "scopeName": "source.catspeak",
  "fileTypes": [
    "meow"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#raw-strings" },
    { "include": "#character-literals" },
    { "include": "#colour-codes" },
    { "include": "#numbers" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#raw-identifiers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.catspeak",
          "match": "--.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.catspeak",
          "match": "\\b(if|else|while|for|return|break|continue|throw|catch|do|match|with|loop)\\b"
        },
        {
          "name": "keyword.other.catspeak",
          "match": "\\b(let|fun|new|impl|params)\\b"
        },
        {
          "name": "variable.language.catspeak",
          "match": "\\b(self|other)\\b"
        },
        {
          "name": "constant.language.boolean.catspeak",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.catspeak",
          "match": "\\b(undefined|infinity|NaN)\\b"
        },
        {
          "name": "keyword.operator.logical.catspeak",
          "match": "\\b(and|or|xor)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.catspeak",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.catspeak",
              "match": "\\\\([\"\\\\/bfnrt]|u[0-9a-fA-F]{4})"
            },
            {
              "name": "invalid.illegal.unrecognized-escape.catspeak",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "raw-strings": {
      "patterns": [
        {
          "name": "string.quoted.double.raw.catspeak",
          "match": "@\"[^\"]*\""
        }
      ]
    },
    "character-literals": {
      "patterns": [
        {
          "name": "string.quoted.single.catspeak",
          "match": "'([^'\\\\]|\\\\.)'"
        }
      ]
    },
    "colour-codes": {
      "patterns": [
        {
          "name": "constant.other.color.catspeak",
          "match": "#[0-9a-fA-F]{8}\\b"
        },
        {
          "name": "constant.other.color.catspeak",
          "match": "#[0-9a-fA-F]{6}\\b"
        },
        {
          "name": "constant.other.color.catspeak",
          "match": "#[0-9a-fA-F]{4}\\b"
        },
        {
          "name": "constant.other.color.catspeak",
          "match": "#[0-9a-fA-F]{3}\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.binary.catspeak",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.hex.catspeak",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.decimal.catspeak",
          "match": "\\b[0-9][0-9_]*\\.?[0-9_]*([eE][+-]?[0-9_]+)?\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.catspeak",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.catspeak",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.comparison.catspeak",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.catspeak",
          "match": "(\\+|-|\\*|/|//|%)"
        },
        {
          "name": "keyword.operator.bitwise.catspeak",
          "match": "(&|\\||\\^|<<|>>)"
        },
        {
          "name": "keyword.operator.pipeline.catspeak",
          "match": "(<\\||\\|>)"
        },
        {
          "name": "keyword.operator.logical.catspeak",
          "match": "(!|~)"
        }
      ]
    },
    "raw-identifiers": {
      "patterns": [
        {
          "name": "variable.other.raw.catspeak",
          "match": "`[^`]+`"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.catspeak",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
